{
  "env": { "browser": true, "es2022": true },
  "parserOptions": { "ecmaVersion": 2022, "sourceType": "module" },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "warn",
    "eqeqeq": ["warn", "always", { "null": "ignore" }],
    "no-var": "error",
    "prefer-const": "warn"
  },
  "globals": {
    "ApexCharts": "readonly",
    "echarts": "readonly"
  },
  "ignorePatterns": ["sw.js", "js/update-checker.js"]
}
