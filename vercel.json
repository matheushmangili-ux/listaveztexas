{
  "rewrites": [
    { "source": "/landing", "destination": "/landing.html" },
    { "source": "/:slug/login", "destination": "/index.html" },
    { "source": "/:slug/tablet", "destination": "/tablet.html" },
    { "source": "/:slug/dashboard", "destination": "/dashboard.html" },
    { "source": "/:slug/setup", "destination": "/setup.html" },
    { "source": "/:slug/settings", "destination": "/settings.html" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
